{
  "name": "8byte-devops-app",
  "version": "1.0.0",
  "description": "Demo app for 8byte DevOps assignment",
  "main": "src/index.js",
  "scripts": {
    "start":   "node src/index.js",
    "dev":     "nodemon src/index.js",
    "test":    "jest --coverage --forceExit",
    "test:ci": "jest --coverage --forceExit --ci"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg":      "^8.11.3"
  },
  "devDependencies": {
    "jest":       "^29.7.0",
    "supertest":  "^6.3.4",
    "nodemon":    "^3.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["src/**/*.js"]
  }
}
